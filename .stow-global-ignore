^/COPYING.*

# --- Version Control ---
\.git$
\.gitignore$
\.gitmodules$
\.gitattributes$

# --- Build & Task Artifacts ---
# Matches your .tasks folders seen in your tree
\.tasks$
# Common Makefile and build artifacts
^/Makefile$
\.o$
\.lo$
\.la$

# --- Editor & System Junk ---
# Emacs/Vim backup files
.+~
\#.*\#
\.swp$
\.swo$
